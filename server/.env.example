# 服务端口
PORT=3000

# MongoDB 连接串（本地 or MongoDB Atlas）
MONGODB_URI=mongodb://localhost:27017/xloop

# JWT 密钥（必须设置，建议 32 位以上随机字符串）
JWT_SECRET=change_me_to_a_long_random_string

# 腾讯云 SES 邮件服务配置
SES_SECRET_ID=your_secret_id
SES_SECRET_KEY=your_secret_key
SES_REGION=ap-guangzhou
SES_ENDPOINT=ses.tencentcloudapi.com
SES_SENDER=noreply@example.com
SES_TEMPLATE_ID=12345
SES_SUBJECT=X-Loop 校园邮箱验证码
SES_REPLY_TO=noreply@example.com

# 邮件开发模式：true 时不发真实邮件，只打印验证码到控制台
EMAIL_DEV_MODE=true

# 验证码哈希盐值（SHA256(email:code:salt)）
EMAIL_CODE_SALT=x-loop-email-code

# Cloudinary unsigned upload 配置
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_UPLOAD_PRESET=your_unsigned_preset
