.page-group-buy {
  min-height: 100vh;
  background: #F5F3F7;
}

.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: linear-gradient(to right, #010544, #CE57C1);
}

.nav-bar-inner {
  height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 20rpx;
}

.nav-back { display: flex; align-items: center; }
.nav-back-arrow { color: #fff; font-size: 36rpx; margin-right: 12rpx; }
.nav-title { color: #fff; font-size: 34rpx; font-weight: bold; }
.nav-action-text { color: #fff; font-size: 28rpx; }

.role-tabs { display: flex; background: #fff; padding: 0 40rpx; }
.role-tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; border-bottom: 4rpx solid transparent; }
.role-tab-active { color: #CE57C1; font-weight: bold; border-bottom-color: #CE57C1; }

/* 发布表单 */
.publish-form { margin: 20rpx; }
.form-input { border-bottom: 1rpx solid #f0f0f0; padding: 20rpx 0; font-size: 30rpx; }
.form-textarea { width: 100%; height: 160rpx; border-bottom: 1rpx solid #f0f0f0; padding: 20rpx 0; font-size: 28rpx; }
.form-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-label { font-size: 28rpx; color: #666; }
.form-input-sm { width: 200rpx; text-align: right; font-size: 28rpx; }
.form-date-text { font-size: 28rpx; color: #333; }
.form-images { display: flex; flex-wrap: wrap; gap: 16rpx; padding: 20rpx 0; }
.form-image-item { position: relative; width: 180rpx; height: 180rpx; }
.form-image { width: 100%; height: 100%; border-radius: 12rpx; }
.form-image-del { position: absolute; top: -10rpx; right: -10rpx; width: 40rpx; height: 40rpx; background: #ff4d4f; color: #fff; border-radius: 50%; text-align: center; line-height: 40rpx; font-size: 24rpx; }
.form-image-add { width: 180rpx; height: 180rpx; border: 2rpx dashed #ddd; border-radius: 12rpx; display: flex; align-items: center; justify-content: center; }
.form-image-add-icon { font-size: 60rpx; color: #ccc; }
.form-submit { margin-top: 30rpx; text-align: center; }

/* 团购列表 */
.group-list { padding: 20rpx; }
.group-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.group-top { display: flex; align-items: center; margin-bottom: 16rpx; }
.group-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 16rpx; }
.group-info { flex: 1; }
.group-title { font-size: 30rpx; font-weight: bold; color: #333; display: block; }
.group-creator { font-size: 22rpx; color: #999; }
.group-desc { font-size: 26rpx; color: #666; margin-bottom: 16rpx; line-height: 1.6; }
.group-images { display: flex; gap: 12rpx; margin-bottom: 16rpx; }
.group-img { width: 200rpx; height: 200rpx; border-radius: 12rpx; }
.group-progress-wrap { margin-bottom: 12rpx; }
.group-progress-bar { height: 12rpx; background: #f0f0f0; border-radius: 6rpx; overflow: hidden; }
.group-progress-fill { height: 100%; background: linear-gradient(to right, #010544, #CE57C1); border-radius: 6rpx; transition: width 0.3s; }
.group-progress-text { font-size: 24rpx; color: #666; margin-top: 8rpx; display: block; }
.group-deadline { font-size: 22rpx; color: #999; }
.group-actions { margin-top: 16rpx; display: flex; justify-content: flex-end; }
.group-join-btn { padding: 12rpx 40rpx; font-size: 26rpx; border-radius: 24rpx; }
.group-joined-tag { padding: 12rpx 40rpx; font-size: 26rpx; color: #999; border: 1rpx solid #ddd; border-radius: 24rpx; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-text { font-size: 32rpx; color: #999; margin-bottom: 16rpx; }
.empty-hint { font-size: 26rpx; color: #ccc; }
