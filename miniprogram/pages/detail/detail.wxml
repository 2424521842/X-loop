<!--商品详情页 - 美化版-->

<!-- 自定义导航栏 -->
<view class="nav-bar" style="padding-top: {{statusBarHeight}}px; height: {{navBarHeight}}px;">
  <view class="nav-bar-inner" style="height: 44px;">
    <view class="nav-back" bindtap="goBack">
      <text class="nav-back-arrow">{{backArrow}}</text>
      <text class="nav-back-text">商品详情</text>
    </view>
  </view>
</view>

<!-- 占位，防止内容被导航栏遮挡 -->
<view style="height: {{navBarHeight}}px;"></view>

<!-- 主内容 -->
<view class="page-detail" wx:if="{{product}}">

  <!-- 商品图片轮播 -->
  <view class="swiper-wrap">
    <swiper class="image-swiper" autoplay circular bindchange="onSwiperChange">
      <swiper-item wx:for="{{product.images}}" wx:key="*this">
        <image
          src="{{item}}"
          mode="aspectFill"
          lazy-load
          class="swiper-image"
          bindtap="previewImage"
          data-index="{{index}}"
        />
      </swiper-item>
    </swiper>
    <!-- 自定义指示器 -->
    <view class="swiper-indicator">
      <text class="swiper-indicator-text">{{currentImageIndex + 1}} / {{product.images.length}}</text>
    </view>
  </view>

  <!-- 商品信息卡片（上方圆角覆盖图片） -->
  <view class="product-card">

    <!-- 标题 -->
    <text class="product-title">{{product.title}}</text>

    <!-- 标签 -->
    <view class="product-tags">
      <text class="tag-pill" wx:if="{{product.categoryName}}">{{product.categoryName}}</text>
      <text class="tag-pill tag-status">{{product.statusText}}</text>
    </view>

    <!-- 价格 -->
    <view class="price-row">
      <text class="price-symbol">¥</text>
      <text class="price-value">{{product.price}}</text>
    </view>

    <!-- 描述 -->
    <view class="desc-section">
      <text class="desc-label">商品描述</text>
      <text class="desc-text">{{product.description}}</text>
    </view>

    <!-- 2列信息网格 -->
    <view class="info-grid">
      <view class="info-grid-item">
        <text class="info-grid-label">交易方式</text>
        <text class="info-grid-value">当面交易</text>
      </view>
      <view class="info-grid-item">
        <text class="info-grid-label">发布时间</text>
        <text class="info-grid-value">{{product.timeText}}</text>
      </view>
    </view>
  </view>

  <!-- 卖家信息卡片 -->
  <view class="seller-card">
    <view class="seller-header">
      <image
        class="seller-avatar"
        src="{{product.seller.avatarUrl || '/images/default-avatar.png'}}"
        mode="aspectFill"
        lazy-load
      />
      <view class="seller-info">
        <text class="seller-name">{{product.seller.nickName || '匿名用户'}}</text>
        <text class="seller-school">西交利物浦大学</text>
      </view>
    </view>
    <view class="seller-stats">
      <view class="stat-item">
        <text class="stat-num">{{product.seller.onSaleCount || '-'}}</text>
        <text class="stat-label">在售</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{product.seller.soldCount || '-'}}</text>
        <text class="stat-label">卖出</text>
      </view>
      <view class="stat-item">
        <text class="stat-num">{{product.seller.credit || '-'}}</text>
        <text class="stat-label">好评</text>
      </view>
    </view>
  </view>

  <!-- 卖家评价 -->
  <review-list targetOpenid="{{product.sellerOpenid}}" wx:if="{{product.sellerOpenid}}" />

  <!-- 底部安全区占位 -->
  <view style="height: 180rpx;"></view>
</view>

<!-- 加载中 -->
<view class="loading-wrap" wx:else>
  <text class="loading-text">加载中...</text>
</view>

<!-- 固定底部操作栏 -->
<view class="bottom-action-bar" wx:if="{{product}}">
  <view class="action-left">
    <view class="action-icon-item">
      <text class="action-icon-label">收藏</text>
    </view>
    <view class="action-icon-item" bindtap="onShareAppMessage">
      <text class="action-icon-label">分享</text>
    </view>
  </view>
  <view class="action-right">
    <button class="btn-chat" plain bindtap="goChat">聊一聊</button>
    <button class="btn-want" bindtap="onBuy">我想要</button>
  </view>
</view>
