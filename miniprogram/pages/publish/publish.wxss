/* 发布页样式 */
.section {
  margin-bottom: 32rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
  display: block;
  margin-bottom: 16rpx;
}

/* 图片上传 */
.image-upload {
  gap: 16rpx;
  margin-bottom: 8rpx;
}

.upload-item {
  width: 200rpx;
  height: 200rpx;
  position: relative;
}

.upload-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.upload-delete {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  background: #ff4d4f;
  color: #fff;
  border-radius: 50%;
  text-align: center;
  line-height: 40rpx;
  font-size: 24rpx;
}

.upload-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-add-icon {
  font-size: 56rpx;
  color: #ccc;
  line-height: 1;
}

.upload-add-text {
  font-size: 22rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 表单 */
.form-input {
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
}

.form-textarea {
  border: 1rpx solid #eee;
  border-radius: 12rpx;
  padding: 20rpx;
  font-size: 28rpx;
  width: 100%;
  height: 240rpx;
  box-sizing: border-box;
}

/* 分类选择 */
.category-select {
  gap: 16rpx;
}

.category-option {
  padding: 12rpx 28rpx;
  border: 1rpx solid #eee;
  border-radius: 24rpx;
  font-size: 26rpx;
  color: #666;
}

.category-option.selected {
  border-color: #CE57C1;
  background: #F0E6F6;
  color: #CE57C1;
}

/* 发布按钮 */
.btn-publish {
  margin-top: 40rpx;
  width: 100%;
}
