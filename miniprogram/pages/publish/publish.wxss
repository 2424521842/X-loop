/* 发布商品页面样式 */

.publish-page {
  padding: 20rpx 24rpx;
  padding-bottom: 40rpx;
}

/* 通用区块 */
.section {
  margin-bottom: 24rpx;
}

.section-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.label {
  font-size: 30rpx;
  font-weight: 600;
  color: #1b1b1e;
}

.sub-label {
  font-size: 24rpx;
  color: #777681;
}

/* 图片上传区域 */
.image-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.uploaded-img {
  width: 100%;
  height: 100%;
}

.delete-btn {
  position: absolute;
  top: 8rpx;
  right: 8rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.55);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.delete-icon {
  color: #ffffff;
  font-size: 24rpx;
  font-weight: bold;
  line-height: 1;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #CE57C1;
  background: #F0E6F6;
  display: flex;
  align-items: center;
  justify-content: center;
}

.add-inner {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.camera-icon {
  font-size: 56rpx;
  color: #CE57C1;
  line-height: 1;
  font-weight: 300;
}

.add-text {
  font-size: 22rpx;
  color: #CE57C1;
  margin-top: 8rpx;
}

.image-tip {
  font-size: 22rpx;
  color: #777681;
  margin-top: 16rpx;
  display: block;
}

/* 表单输入区域 */
.input-group {
  padding: 24rpx 0;
}

.border-bottom {
  border-bottom: 1rpx solid #f0eff2;
}

.input-field {
  width: 100%;
  font-size: 28rpx;
  color: #1b1b1e;
  margin-top: 16rpx;
  padding: 8rpx 0;
}

.textarea-field {
  width: 100%;
  font-size: 28rpx;
  color: #1b1b1e;
  margin-top: 16rpx;
  padding: 8rpx 0;
  min-height: 160rpx;
  box-sizing: border-box;
}

.placeholder {
  color: #b3b1bc;
  font-size: 28rpx;
}

/* 价格行 */
.price-input-wrap {
  display: flex;
  align-items: center;
  margin-top: 16rpx;
}

.yen-sign {
  font-size: 36rpx;
  font-weight: bold;
  color: #FF4D4F;
  margin-right: 8rpx;
}

.price-input {
  flex: 1;
  margin-top: 0;
}

/* 分类选择 */
.category-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.category-chip {
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  background: #f5f3f7;
  font-size: 26rpx;
  color: #464650;
  border: 2rpx solid transparent;
}

.chip-active {
  background: #F0E6F6;
  color: #010544;
  font-weight: 600;
  border-color: #CE57C1;
}

/* 位置行 */
.location-row {
  display: flex;
  flex-direction: row;
  justify-content: space-between;
  align-items: center;
}

.location-text {
  font-size: 26rpx;
  color: #464650;
}

/* 服务条款 */
.terms-wrap {
  text-align: center;
  padding: 16rpx 40rpx;
}

.terms-text {
  font-size: 22rpx;
  color: #b3b1bc;
  line-height: 1.6;
}

/* 底部占位 */
.bottom-placeholder {
  height: 140rpx;
}

/* 固定底部按钮 */
.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 32rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.publish-btn {
  width: 100%;
  height: 88rpx;
  border-radius: 44rpx;
  background: linear-gradient(to right, #010544, #CE57C1);
  display: flex;
  align-items: center;
  justify-content: center;
}

.publish-btn-text {
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}

.btn-disabled {
  opacity: 0.6;
}
