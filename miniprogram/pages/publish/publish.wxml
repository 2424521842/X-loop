<!--发布商品页-->
<view class="page-publish container">
  <view class="card">
    <!--图片上传-->
    <view class="section">
      <text class="section-title">商品图片</text>
      <view class="image-upload flex-row flex-wrap">
        <view wx:for="{{images}}" wx:key="*this" class="upload-item">
          <image src="{{item}}" mode="aspectFill" class="upload-image" />
          <view class="upload-delete" bindtap="deleteImage" data-index="{{index}}">×</view>
        </view>
        <view class="upload-add" bindtap="chooseImage" wx:if="{{images.length < 9}}">
          <text class="upload-add-icon">+</text>
          <text class="upload-add-text">添加图片</text>
        </view>
      </view>
      <text class="text-gray text-small">最多上传9张图片，第一张为封面</text>
    </view>

    <!--商品标题-->
    <view class="section">
      <text class="section-title">商品标题</text>
      <input
        class="form-input"
        placeholder="请输入商品标题"
        maxlength="30"
        value="{{title}}"
        bindinput="onInput"
        data-field="title"
      />
    </view>

    <!--商品描述-->
    <view class="section">
      <text class="section-title">商品描述</text>
      <textarea
        class="form-textarea"
        placeholder="描述一下你的商品（成色、使用时长、转手原因等）"
        maxlength="500"
        value="{{description}}"
        bindinput="onInput"
        data-field="description"
      />
    </view>

    <!--价格-->
    <view class="section">
      <text class="section-title">价格（¥）</text>
      <input
        class="form-input"
        type="digit"
        placeholder="请输入价格"
        value="{{price}}"
        bindinput="onInput"
        data-field="price"
      />
    </view>

    <!--分类-->
    <view class="section">
      <text class="section-title">分类</text>
      <view class="category-select flex-row flex-wrap">
        <view
          wx:for="{{categories}}"
          wx:key="id"
          class="category-option {{selectedCategory === item.id ? 'selected' : ''}}"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >{{item.name}}</view>
      </view>
    </view>
  </view>

  <!--发布按钮-->
  <button class="btn-primary btn-publish" bindtap="onPublish" loading="{{submitting}}">
    发布商品
  </button>
</view>
