<!-- 发布商品页面 -->
<view class="publish-page">

  <!-- 图片上传区域 -->
  <view class="card section">
    <view class="section-header">
      <text class="label">商品图片</text>
      <text class="sub-label">{{images.length}}/9</text>
    </view>
    <view class="image-grid">
      <!-- 已上传的图片 -->
      <view class="image-item" wx:for="{{images}}" wx:key="*this">
        <image class="uploaded-img" src="{{item}}" mode="aspectFill" lazy-load />
        <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">
          <text class="delete-icon">x</text>
        </view>
      </view>
      <!-- 添加图片按钮 -->
      <view class="image-add" bindtap="chooseImage" wx:if="{{images.length < 9}}">
        <view class="add-inner">
          <text class="camera-icon">+</text>
          <text class="add-text">上传图片</text>
        </view>
      </view>
    </view>
    <text class="image-tip">最多可上传9张照片</text>
  </view>

  <!-- 表单区域 -->
  <view class="card section">
    <!-- 标题输入 -->
    <view class="input-group border-bottom">
      <text class="label">标题</text>
      <input
        class="input-field"
        placeholder="给你的宝贝起个名字..."
        placeholder-class="placeholder"
        value="{{title}}"
        data-field="title"
        bindinput="onInput"
        maxlength="30"
      />
    </view>

    <!-- 描述输入 -->
    <view class="input-group border-bottom">
      <text class="label">描述</text>
      <textarea
        class="textarea-field"
        placeholder="描述一下宝贝的品牌、型号、新旧程度、入手渠道等..."
        placeholder-class="placeholder"
        value="{{description}}"
        data-field="description"
        bindinput="onInput"
        maxlength="500"
        auto-height
      />
    </view>

    <!-- 价格输入 -->
    <view class="input-group border-bottom">
      <text class="label">价格</text>
      <view class="price-input-wrap">
        <text class="yen-sign">¥</text>
        <input
          class="input-field price-input"
          type="digit"
          placeholder="输入价格"
          placeholder-class="placeholder"
          value="{{price}}"
          data-field="price"
          bindinput="onInput"
        />
      </view>
    </view>

    <!-- 分类选择 -->
    <view class="input-group border-bottom">
      <text class="label">选择分类</text>
      <view class="category-list">
        <view
          class="category-chip {{selectedCategory === item.id ? 'chip-active' : ''}}"
          wx:for="{{categories}}"
          wx:key="id"
          bindtap="selectCategory"
          data-id="{{item.id}}"
        >
          <text>{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 发布位置 -->
    <view class="input-group location-row">
      <text class="label">发布位置</text>
      <text class="location-text">XJTLU 西交利物浦大学</text>
    </view>
  </view>

  <!-- 服务条款提示 -->
  <view class="terms-wrap">
    <text class="terms-text">发布即表示同意X-Loop平台服务条款，请确保商品信息真实有效</text>
  </view>

  <!-- 底部占位，防止按钮遮挡内容 -->
  <view class="bottom-placeholder"></view>
</view>

<!-- 固定底部发布按钮 -->
<view class="fixed-bottom">
  <view class="publish-btn {{submitting ? 'btn-disabled' : ''}}" bindtap="onPublish">
    <text class="publish-btn-text">{{submitting ? '发布中...' : '确认发布'}}</text>
  </view>
</view>
