<!--首页 - 商品列表-->
<view class="page-index">
  <!--搜索栏-->
  <view class="search-bar" bindtap="goSearch">
    <view class="search-input">
      <text class="search-icon">🔍</text>
      <text class="search-placeholder">搜索你想要的商品</text>
    </view>
  </view>

  <!--分类导航-->
  <scroll-view class="category-bar" scroll-x enable-flex>
    <view
      class="category-item {{currentCategory === '' ? 'active' : ''}}"
      bindtap="switchCategory"
      data-id=""
    >全部</view>
    <view
      wx:for="{{categories}}"
      wx:key="id"
      class="category-item {{currentCategory === item.id ? 'active' : ''}}"
      bindtap="switchCategory"
      data-id="{{item.id}}"
    >{{item.name}}</view>
  </scroll-view>

  <!--商品列表-->
  <view class="product-list">
    <view
      wx:for="{{products}}"
      wx:key="_id"
      class="product-card card"
      bindtap="goDetail"
      data-id="{{item._id}}"
    >
      <image
        class="product-image"
        src="{{item.images[0]}}"
        mode="aspectFill"
        lazy-load
      />
      <view class="product-info">
        <text class="product-title text-ellipsis">{{item.title}}</text>
        <text class="price">{{item.price}}</text>
        <view class="product-meta flex-between">
          <text class="text-gray text-small">{{item.categoryName}}</text>
          <text class="text-gray text-small">{{item.timeText}}</text>
        </view>
      </view>
    </view>
  </view>

  <!--加载状态-->
  <view class="loading-tip" wx:if="{{loading}}">
    <text>加载中...</text>
  </view>
  <view class="loading-tip" wx:elif="{{noMore}}">
    <text class="text-gray">没有更多了</text>
  </view>
  <view class="empty-tip" wx:elif="{{products.length === 0}}">
    <text>暂无商品，快去发布吧~</text>
  </view>
</view>
