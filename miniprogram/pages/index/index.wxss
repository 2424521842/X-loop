/* 首页样式 - Stitch Design System */

/* ===== 自定义导航栏 ===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background: linear-gradient(to right, #010544, #CE57C1);
}

.nav-bar-content {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 44px;
  padding: 0 30rpx;
}

.nav-left {
  display: flex;
  align-items: center;
}

.nav-brand {
  font-weight: 800;
  font-size: 36rpx;
  letter-spacing: 4rpx;
  color: #ffffff;
}

/* ===== Hero 区域 ===== */
.hero-section {
  position: relative;
  padding: 48rpx 40rpx 64rpx;
  background: linear-gradient(to bottom, #fbf8fc, #f5f3f7);
  overflow: hidden;
}

.hero-content {
  position: relative;
  z-index: 2;
}

.hero-title {
  margin-bottom: 12rpx;
  display: flex;
  flex-wrap: wrap;
}

.hero-title-text {
  font-size: 52rpx;
  font-weight: 800;
  color: #0d144e;
  line-height: 1.3;
}

.hero-title-accent {
  font-size: 52rpx;
  font-weight: 800;
  color: #cb55bf;
  line-height: 1.3;
}

.hero-subtitle {
  color: #464650;
  font-size: 26rpx;
  font-weight: 500;
  margin-bottom: 40rpx;
  display: block;
}

/* 搜索栏 */
.search-bar {
  display: flex;
  align-items: center;
  background: #ffffff;
  box-shadow: 0 8rpx 40rpx rgba(1, 5, 68, 0.04);
  border-radius: 24rpx;
  padding: 24rpx 28rpx;
}

.search-bar icon {
  margin-right: 16rpx;
}

.search-placeholder {
  flex: 1;
  color: #777681;
  font-size: 28rpx;
  font-weight: 500;
}

/* 背景装饰 */
.hero-decoration {
  position: absolute;
  top: -80rpx;
  right: -80rpx;
  width: 300rpx;
  height: 300rpx;
  background: rgba(203, 85, 191, 0.05);
  border-radius: 50%;
}

/* ===== 分类区域 ===== */
.category-section {
  margin-bottom: 40rpx;
}

.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 40rpx;
  margin-bottom: 24rpx;
}

.category-title {
  font-size: 24rpx;
  font-weight: 700;
  letter-spacing: 2rpx;
  color: #464650;
}

.category-more {
  font-size: 24rpx;
  font-weight: 600;
  color: #cb55bf;
}

.category-scroll {
  white-space: nowrap;
  padding-left: 40rpx;
  padding-right: 40rpx;
}

.category-chip {
  display: inline-block;
  padding: 16rpx 36rpx;
  background: #F0E6F6;
  color: #010544;
  border-radius: 16rpx;
  font-size: 24rpx;
  font-weight: 700;
  margin-right: 20rpx;
}

.category-chip.active {
  background: linear-gradient(135deg, #010544, #CE57C1);
  color: #ffffff;
}

/* ===== 商品网格 ===== */
.product-grid {
  display: flex;
  flex-wrap: wrap;
  padding: 0 30rpx;
  justify-content: space-between;
}

.product-card {
  width: 332rpx;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  margin-bottom: 24rpx;
  box-shadow: 0 4rpx 20rpx rgba(1, 5, 68, 0.03);
}

/* 卡片图片 */
.card-image-wrap {
  width: 100%;
  height: 332rpx;
  overflow: hidden;
}

.card-image {
  width: 100%;
  height: 100%;
}

/* 卡片内容 */
.card-body {
  padding: 20rpx 24rpx 24rpx;
}

.card-title {
  color: #1b1b1e;
  font-weight: 700;
  font-size: 28rpx;
  line-height: 1.3;
  margin-bottom: 8rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

.card-location-text {
  font-size: 20rpx;
  color: #464650;
  display: block;
  margin-bottom: 16rpx;
}

.card-footer {
  display: flex;
  align-items: flex-end;
  justify-content: space-between;
}

.card-price {
  color: #ff4d4f;
  font-weight: 800;
  font-size: 34rpx;
  letter-spacing: -1rpx;
}

/* ===== 浮动发布按钮 ===== */
.fab-btn {
  position: fixed;
  bottom: 180rpx;
  right: 40rpx;
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #010544, #CE57C1);
  box-shadow: 0 16rpx 48rpx rgba(1, 5, 68, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  z-index: 40;
}

.fab-icon {
  font-size: 44rpx;
  color: #ffffff;
  font-weight: 300;
  line-height: 1;
}

/* ===== 加载状态 ===== */
.loading-tip,
.empty-tip {
  text-align: center;
  padding: 60rpx 40rpx;
  color: #777681;
  font-size: 26rpx;
  width: 100%;
}

/* ===== 整体页面 ===== */
.page-index {
  padding-bottom: 40rpx;
}
