/* 搜索页样式 */
.search-header {
  padding: 20rpx;
  background: linear-gradient(to right, #010544, #CE57C1);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #fff;
  border-radius: 32rpx;
  padding: 12rpx 20rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
}

.search-btn {
  color: #CE57C1;
  font-size: 28rpx;
  padding-left: 20rpx;
  font-weight: bold;
}

/* 筛选栏 */
.filter-bar {
  background: #fff;
  padding: 16rpx 0;
  border-bottom: 1rpx solid #eee;
  justify-content: center;
  gap: 40rpx;
}

.filter-item {
  font-size: 26rpx;
  color: #666;
  padding: 8rpx 24rpx;
}

.filter-item.active {
  color: #CE57C1;
  font-weight: bold;
}

/* 搜索结果 */
.result-list {
  padding: 20rpx;
}

.result-item {
  padding: 20rpx;
}

.result-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
}

.result-info {
  display: flex;
  flex-direction: column;
  justify-content: space-between;
}

.result-title {
  font-size: 28rpx;
  line-height: 1.4;
  margin-bottom: 12rpx;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 搜索历史 */
.search-history {
  padding: 30rpx;
}

.section-title {
  font-size: 30rpx;
  font-weight: bold;
}

.history-tags {
  margin-top: 20rpx;
  gap: 16rpx;
}

.empty-tip {
  text-align: center;
  padding: 100rpx;
  color: #999;
}
