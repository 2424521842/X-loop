/* 搜索结果页样式 */

.page-search {
  min-height: 100vh;
  background: #f5f3f7;
}

/* ========== 自定义导航栏 ========== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  width: 100%;
  z-index: 100;
  background: linear-gradient(to right, #010544, #CE57C1);
  box-sizing: border-box;
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  justify-content: space-between;
  height: 88rpx;
  padding: 0 24rpx;
}

.nav-back {
  width: 80rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: flex-start;
}

.nav-back-arrow {
  width: 20rpx;
  height: 20rpx;
  border-left: 4rpx solid #ffffff;
  border-bottom: 4rpx solid #ffffff;
  transform: rotate(45deg);
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 600;
}

.nav-placeholder {
  width: 80rpx;
}

/* ========== 搜索栏吸顶 ========== */
.search-bar-sticky {
  position: sticky;
  z-index: 90;
  background: #ffffff;
  padding: 16rpx 24rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}

.search-bar-wrap {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.search-input-box {
  flex: 1;
  display: flex;
  align-items: center;
  background: #f5f3f7;
  border-radius: 36rpx;
  padding: 14rpx 24rpx;
  gap: 12rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  color: #1b1b1e;
  height: 40rpx;
  line-height: 40rpx;
}

.search-btn {
  background: linear-gradient(to right, #010544, #CE57C1);
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 600;
  padding: 14rpx 32rpx;
  border-radius: 36rpx;
  white-space: nowrap;
}

/* ========== 筛选标签行 ========== */
.filter-section {
  background: #ffffff;
  padding: 16rpx 0 16rpx 24rpx;
  border-bottom: 1rpx solid #f0e6f6;
}

.filter-scroll {
  white-space: nowrap;
  display: flex;
}

.filter-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  background: #f5f3f7;
  color: #464650;
  font-size: 24rpx;
  padding: 12rpx 28rpx;
  border-radius: 32rpx;
  margin-right: 16rpx;
  flex-shrink: 0;
}

.filter-chip-active {
  background: #F0E6F6;
  color: #010544;
  font-weight: 600;
}

/* ========== 结果计数与排序 ========== */
.result-meta {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 20rpx 32rpx 8rpx;
}

.result-count {
  font-size: 24rpx;
  color: #777681;
}

.result-sort {
  font-size: 24rpx;
  color: #464650;
  font-weight: 500;
}

/* ========== 结果列表 ========== */
.result-list {
  padding: 16rpx 24rpx;
}

.result-card {
  display: flex;
  flex-direction: row;
  background: #ffffff;
  border-radius: 32rpx;
  overflow: hidden;
  margin-bottom: 20rpx;
  box-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.06);
}

.result-card-img {
  width: 256rpx;
  height: 256rpx;
  flex-shrink: 0;
}

.result-card-body {
  flex: 1;
  display: flex;
  flex-direction: column;
  justify-content: space-between;
  padding: 24rpx;
  min-width: 0;
}

.result-card-title {
  font-size: 28rpx;
  font-weight: 500;
  color: #1b1b1e;
  line-height: 1.5;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
  text-overflow: ellipsis;
}

.result-card-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 12rpx;
}

.result-tag {
  display: inline-block;
  font-size: 20rpx;
  color: #CE57C1;
  background: #F0E6F6;
  padding: 4rpx 16rpx;
  border-radius: 16rpx;
}

.result-card-bottom {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 12rpx;
}

.result-card-price {
  font-size: 34rpx;
  font-weight: 700;
  color: #FF4D4F;
}

.result-card-price::before {
  content: "\00A5";
  font-size: 24rpx;
  font-weight: 600;
}

.result-card-location {
  font-size: 22rpx;
  color: #777681;
}

/* ========== 加载状态 ========== */
.loading-wrap {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 0;
}

.loading-spinner {
  width: 48rpx;
  height: 48rpx;
  border: 4rpx solid #F0E6F6;
  border-top-color: #CE57C1;
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

.loading-text {
  font-size: 26rpx;
  color: #777681;
  margin-top: 20rpx;
}

/* ========== 空状态 ========== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 160rpx 0 80rpx;
}

.empty-icon {
  font-size: 80rpx;
  color: #CE57C1;
  margin-bottom: 24rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #1b1b1e;
  font-weight: 500;
}

.empty-sub {
  font-size: 24rpx;
  color: #777681;
  margin-top: 12rpx;
}

/* ========== 搜索历史 ========== */
.history-section {
  padding: 40rpx 32rpx;
}

.history-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 24rpx;
}

.history-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #1b1b1e;
}

.history-clear {
  font-size: 24rpx;
  color: #777681;
}

.history-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.history-chip {
  display: inline-block;
  font-size: 24rpx;
  color: #464650;
  background: #ffffff;
  padding: 14rpx 28rpx;
  border-radius: 32rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.04);
}
