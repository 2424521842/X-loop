<view class="page-agent-buy">
  <!-- 自定义导航栏 -->
  <view class="nav-bar" style="padding-top: {{statusBarHeight}}px;">
    <view class="nav-bar-inner">
      <view class="nav-back" bindtap="goBack">
        <text class="nav-back-arrow">&lt;</text>
        <text class="nav-title">代购</text>
      </view>
      <view class="nav-action" bindtap="togglePublish">
        <text class="nav-action-text">{{showPublish ? '取消' : '发布需求'}}</text>
      </view>
    </view>
  </view>
  <view style="height: {{navBarHeight}}px;"></view>

  <!-- 发布表单 -->
  <view class="publish-form card" wx:if="{{showPublish}}">
    <textarea class="form-textarea" placeholder="描述你需要代购的物品..." value="{{form.description}}" bindinput="onFormInput" data-field="description" />
    <view class="form-row">
      <text class="form-label">预算 (¥)</text>
      <input class="form-input-sm" type="digit" placeholder="0.00" value="{{form.budget}}" bindinput="onFormInput" data-field="budget" />
    </view>
    <view class="form-row">
      <text class="form-label">佣金 (¥)</text>
      <input class="form-input-sm" type="digit" placeholder="0.00" value="{{form.commission}}" bindinput="onFormInput" data-field="commission" />
    </view>
    <view class="btn-primary form-submit" bindtap="submitAgentBuy">发布需求</view>
  </view>

  <!-- 切换标签 -->
  <view class="role-tabs" wx:if="{{!showPublish}}">
    <view class="role-tab {{activeTab === 'list' ? 'role-tab-active' : ''}}" bindtap="switchTab" data-tab="list">
      <text>需求大厅</text>
    </view>
    <view class="role-tab {{activeTab === 'mine' ? 'role-tab-active' : ''}}" bindtap="switchTab" data-tab="mine">
      <text>我的相关</text>
    </view>
  </view>

  <!-- 列表 -->
  <view class="agent-list" wx:if="{{agentBuys.length > 0 && !showPublish}}">
    <view class="agent-card" wx:for="{{agentBuys}}" wx:key="_id">
      <view class="agent-top">
        <image class="agent-avatar" src="{{item.requester.avatarUrl || '/images/default-avatar.png'}}" mode="aspectFill" lazy-load />
        <view class="agent-info">
          <text class="agent-requester">{{item.requester.nickName}}</text>
          <text class="agent-time">{{item.timeText}}</text>
        </view>
        <text class="agent-status tag {{item.status === 'open' ? 'tag-green' : item.status === 'completed' ? 'tag-gray' : 'tag-green'}}">
          {{item.statusText}}
        </text>
      </view>
      <text class="agent-desc">{{item.description}}</text>
      <view class="agent-price-row">
        <view class="agent-price-item">
          <text class="agent-price-label">预算</text>
          <text class="agent-price-value">¥{{item.budget}}</text>
        </view>
        <view class="agent-price-item">
          <text class="agent-price-label">佣金</text>
          <text class="agent-price-value price-commission">¥{{item.commission}}</text>
        </view>
      </view>
      <!-- 代购人信息 -->
      <view class="agent-accepted" wx:if="{{item.agent}}">
        <text class="agent-accepted-label">代购人：</text>
        <text class="agent-accepted-name">{{item.agent.nickName}}</text>
      </view>
      <!-- 操作 -->
      <view class="agent-actions">
        <view class="order-btn order-btn-chat" wx:if="{{item.isRequester && item.agent}}" bindtap="goChat" data-openid="{{item.agentOpenid}}">
          <text>联系代购</text>
        </view>
        <view class="order-btn order-btn-chat" wx:if="{{item.isAgent}}" bindtap="goChat" data-openid="{{item.requesterOpenid}}">
          <text>联系发布者</text>
        </view>
        <view class="order-btn order-btn-primary" wx:if="{{item.status === 'open' && !item.isRequester}}" bindtap="onAction" data-id="{{item._id}}" data-action="accept">
          <text>接单</text>
        </view>
        <view class="order-btn order-btn-primary" wx:if="{{item.status === 'accepted' && item.isRequester}}" bindtap="onAction" data-id="{{item._id}}" data-action="complete">
          <text>确认完成</text>
        </view>
        <view class="order-btn order-btn-cancel" wx:if="{{(item.status === 'open' || item.status === 'accepted') && item.isRequester}}" bindtap="onAction" data-id="{{item._id}}" data-action="cancel">
          <text>取消</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view class="empty-state" wx:elif="{{!loading && !showPublish}}">
    <text class="empty-text">暂无代购需求</text>
    <text class="empty-hint">点击右上角发布代购需求~</text>
  </view>
</view>
