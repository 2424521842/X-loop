.page-agent-buy {
  min-height: 100vh;
  background: #F5F3F7;
}

.nav-bar {
  position: fixed; top: 0; left: 0; right: 0; z-index: 100;
  background: linear-gradient(to right, #010544, #CE57C1);
}

.nav-bar-inner {
  height: 44px; display: flex; align-items: center; justify-content: space-between; padding: 0 20rpx;
}

.nav-back { display: flex; align-items: center; }
.nav-back-arrow { color: #fff; font-size: 36rpx; margin-right: 12rpx; }
.nav-title { color: #fff; font-size: 34rpx; font-weight: bold; }
.nav-action-text { color: #fff; font-size: 28rpx; }

.role-tabs { display: flex; background: #fff; padding: 0 40rpx; }
.role-tab { flex: 1; text-align: center; padding: 24rpx 0; font-size: 30rpx; color: #666; border-bottom: 4rpx solid transparent; }
.role-tab-active { color: #CE57C1; font-weight: bold; border-bottom-color: #CE57C1; }

.publish-form { margin: 20rpx; }
.form-textarea { width: 100%; height: 200rpx; border-bottom: 1rpx solid #f0f0f0; padding: 20rpx 0; font-size: 28rpx; }
.form-row { display: flex; align-items: center; justify-content: space-between; padding: 20rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.form-label { font-size: 28rpx; color: #666; }
.form-input-sm { width: 200rpx; text-align: right; font-size: 28rpx; }
.form-submit { margin-top: 30rpx; text-align: center; }

.agent-list { padding: 20rpx; }
.agent-card { background: #fff; border-radius: 16rpx; padding: 24rpx; margin-bottom: 20rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.05); }
.agent-top { display: flex; align-items: center; margin-bottom: 16rpx; }
.agent-avatar { width: 72rpx; height: 72rpx; border-radius: 50%; margin-right: 16rpx; }
.agent-info { flex: 1; }
.agent-requester { font-size: 28rpx; font-weight: bold; color: #333; display: block; }
.agent-time { font-size: 22rpx; color: #999; }
.agent-desc { font-size: 28rpx; color: #666; line-height: 1.6; margin-bottom: 16rpx; }
.agent-price-row { display: flex; gap: 40rpx; margin-bottom: 16rpx; }
.agent-price-item { display: flex; flex-direction: column; }
.agent-price-label { font-size: 22rpx; color: #999; }
.agent-price-value { font-size: 32rpx; font-weight: bold; color: #ff4d4f; }
.price-commission { color: #CE57C1; }
.agent-accepted { font-size: 24rpx; color: #666; margin-bottom: 16rpx; }
.agent-accepted-name { color: #CE57C1; }

.agent-actions { display: flex; justify-content: flex-end; gap: 16rpx; padding-top: 16rpx; border-top: 1rpx solid #f5f5f5; }
.order-btn { padding: 12rpx 28rpx; border-radius: 24rpx; font-size: 24rpx; }
.order-btn-chat { border: 1rpx solid #ddd; color: #666; }
.order-btn-primary { background: #CE57C1; color: #fff; }
.order-btn-cancel { border: 1rpx solid #ddd; color: #999; }

.empty-state { display: flex; flex-direction: column; align-items: center; padding-top: 200rpx; }
.empty-text { font-size: 32rpx; color: #999; margin-bottom: 16rpx; }
.empty-hint { font-size: 26rpx; color: #ccc; }
