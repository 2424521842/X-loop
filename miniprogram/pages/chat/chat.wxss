/* 聊天详情页样式 */

.page-chat {
  background: #f5f3f7;
  min-height: 100vh;
}

/* ===== 自定义导航栏 ===== */
.nav-bar {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  z-index: 100;
  background: linear-gradient(to right, #010544, #CE57C1);
}

.nav-bar-inner {
  display: flex;
  align-items: center;
  height: 44px;
  padding: 0 30rpx;
}

.nav-back {
  display: flex;
  align-items: center;
}

.nav-back-arrow {
  font-size: 36rpx;
  color: #ffffff;
  margin-right: 16rpx;
  font-weight: bold;
}

.nav-title {
  font-size: 34rpx;
  color: #ffffff;
  font-weight: 700;
}

/* ===== 商品引用卡片 ===== */
.product-ref-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  background: rgba(255, 255, 255, 0.9);
  padding: 20rpx 24rpx;
  border-bottom: 1rpx solid rgba(199, 197, 209, 0.1);
}

.product-ref-left {
  display: flex;
  align-items: center;
  flex: 1;
  overflow: hidden;
}

.product-ref-img {
  width: 80rpx;
  height: 80rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.product-ref-info {
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.product-ref-title {
  font-size: 26rpx;
  font-weight: 600;
  color: #1b1b1e;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.product-ref-price {
  font-size: 24rpx;
  font-weight: 700;
  color: #ff4d4f;
  margin-top: 4rpx;
}

.product-ref-btn {
  background: #e9e7eb;
  padding: 12rpx 24rpx;
  border-radius: 999rpx;
  flex-shrink: 0;
  margin-left: 16rpx;
}

.product-ref-btn-text {
  font-size: 22rpx;
  font-weight: 600;
  color: #434a84;
}

/* ===== 聊天消息列表 ===== */
.chat-scroll {
  width: 100%;
}

.chat-list {
  padding: 32rpx 24rpx;
}

/* 消息行 */
.msg-row {
  display: flex;
  align-items: flex-start;
  margin-bottom: 40rpx;
  gap: 16rpx;
}

.msg-mine {
  flex-direction: row-reverse;
}

/* 头像 */
.msg-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  flex-shrink: 0;
}

.msg-avatar-me {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: linear-gradient(135deg, #010544, #CE57C1);
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.avatar-me-text {
  font-size: 20rpx;
  color: #ffffff;
  font-weight: 700;
}

/* 消息内容 */
.msg-content-wrap {
  display: flex;
  flex-direction: column;
  max-width: 65%;
}

.msg-mine .msg-content-wrap {
  align-items: flex-end;
}

.msg-bubble {
  padding: 20rpx 28rpx;
  border-radius: 28rpx;
  box-shadow: 0 4rpx 12rpx rgba(1, 5, 68, 0.04);
}

.bubble-other {
  background: #ffffff;
  border-top-left-radius: 4rpx;
}

.bubble-mine {
  background: #cb55bf;
  border-top-right-radius: 4rpx;
}

.bubble-other .msg-text {
  color: #1b1b1e;
}

.bubble-mine .msg-text {
  color: #ffffff;
}

.msg-text {
  font-size: 28rpx;
  line-height: 1.6;
}

.msg-time {
  font-size: 20rpx;
  color: #777681;
  margin-top: 8rpx;
  padding: 0 8rpx;
}

/* 空消息 */
.empty-chat {
  display: flex;
  justify-content: center;
  padding: 120rpx 0;
}

.empty-chat-text {
  font-size: 28rpx;
  color: #777681;
}

/* ===== 底部输入栏 ===== */
.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #ffffff;
  border-top: 1rpx solid rgba(199, 197, 209, 0.1);
}

.input-wrap {
  flex: 1;
  background: #f5f3f7;
  border-radius: 32rpx;
  padding: 0 28rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
}

.chat-input {
  width: 100%;
  font-size: 28rpx;
  color: #1b1b1e;
}

.send-btn {
  background: #cb55bf;
  padding: 0 36rpx;
  height: 72rpx;
  border-radius: 999rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
}

.send-btn-text {
  font-size: 28rpx;
  color: #ffffff;
  font-weight: 600;
}
