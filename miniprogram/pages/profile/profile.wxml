<!--个人中心页-->
<view class="page-profile">
  <!--用户信息-->
  <view class="user-header" style="background: linear-gradient(to right, #010544, #CE57C1);">
    <block wx:if="{{userInfo}}">
      <image class="user-avatar" src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}" />
      <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
      <text class="user-credit">信誉分：{{userInfo.credit || 100}}</text>
    </block>
    <block wx:else>
      <view class="login-btn" bindtap="onLogin">
        <image class="user-avatar" src="/images/default-avatar.png" />
        <text class="user-name">点击登录</text>
      </view>
    </block>
  </view>

  <!--统计-->
  <view class="stats-bar card flex-between" wx:if="{{userInfo}}">
    <view class="stat-item flex-col flex-center">
      <text class="stat-num">{{stats.published || 0}}</text>
      <text class="text-gray text-small">已发布</text>
    </view>
    <view class="stat-item flex-col flex-center">
      <text class="stat-num">{{stats.sold || 0}}</text>
      <text class="text-gray text-small">已卖出</text>
    </view>
    <view class="stat-item flex-col flex-center">
      <text class="stat-num">{{stats.bought || 0}}</text>
      <text class="text-gray text-small">已购买</text>
    </view>
  </view>

  <!--菜单列表-->
  <view class="menu-list card">
    <view class="menu-item flex-between" bindtap="goMyProducts">
      <text>我发布的</text>
      <text class="text-gray">›</text>
    </view>
    <view class="menu-item flex-between" bindtap="goMyOrders">
      <text>我的订单</text>
      <text class="text-gray">›</text>
    </view>
    <view class="menu-item flex-between" bindtap="goMyFavorites">
      <text>我的收藏</text>
      <text class="text-gray">›</text>
    </view>
  </view>

  <view class="menu-list card">
    <view class="menu-item flex-between" bindtap="goAbout">
      <text>关于 X-Loop</text>
      <text class="text-gray">›</text>
    </view>
    <view class="menu-item flex-between" bindtap="goFeedback">
      <text>意见反馈</text>
      <text class="text-gray">›</text>
    </view>
  </view>
</view>
