<!--个人中心页 - 自定义导航-->
<view class="page-profile">

  <!-- 渐变头部区域 -->
  <view class="hero-header" style="padding-top: {{statusBarHeight}}px;">
    <!-- 装饰性大X -->
    <text class="hero-bg-x">X</text>

    <!-- 用户信息区域 -->
    <view class="hero-content">
      <!-- 已登录状态 -->
      <block wx:if="{{userInfo}}">
        <image
          class="avatar"
          src="{{userInfo.avatarUrl || '/images/default-avatar.png'}}"
          mode="aspectFill"
        />
        <text class="user-name">{{userInfo.nickName || '微信用户'}}</text>
        <view class="school-badge">
          <text class="school-badge-text">西交利物浦大学</text>
        </view>
      </block>

      <!-- 未登录状态 -->
      <block wx:else>
        <view class="avatar-placeholder" bindtap="onLogin">
          <text class="avatar-placeholder-icon">+</text>
        </view>
        <text class="login-text" bindtap="onLogin">点击登录</text>
      </block>
    </view>
  </view>

  <!-- 统计浮动卡片 -->
  <view class="stats-card">
    <view class="stats-item" bindtap="goMyProducts">
      <text class="stats-num">{{stats.published || 0}}</text>
      <text class="stats-label">发布的</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="goMyOrders">
      <text class="stats-num">{{stats.sold || 0}}</text>
      <text class="stats-label">卖出的</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="goMyOrders">
      <text class="stats-num">{{stats.bought || 0}}</text>
      <text class="stats-label">购买到的</text>
    </view>
  </view>

  <!-- 推广横幅卡片 -->
  <view class="promo-card">
    <view class="promo-content">
      <text class="promo-title">校园循环计划</text>
      <text class="promo-desc">让闲置物品重获新生，共建绿色校园</text>
      <view class="promo-btn" bindtap="goAbout">
        <text class="promo-btn-text">了解更多</text>
      </view>
    </view>
    <text class="promo-deco">X</text>
  </view>

  <!-- 菜单列表 -->
  <view class="menu-card">
    <view class="menu-row" bindtap="goMyOrders">
      <view class="menu-icon-box" style="background: #dfe0ff;">
        <text class="menu-icon-star">~</text>
      </view>
      <text class="menu-label">我的订单</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-row" bindtap="goMyMessages">
      <view class="menu-icon-box" style="background: #d7f0ff;">
        <text class="menu-icon-star">@</text>
      </view>
      <text class="menu-label">我的消息</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-row" bindtap="goGroupBuy">
      <view class="menu-icon-box" style="background: #fff0d7;">
        <text class="menu-icon-star">#</text>
      </view>
      <text class="menu-label">拼团</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-row" bindtap="goAgentBuy">
      <view class="menu-icon-box" style="background: #d7ffe0;">
        <text class="menu-icon-star">$</text>
      </view>
      <text class="menu-label">代购</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-row" bindtap="goMyFavorites">
      <view class="menu-icon-box" style="background: #ffd7f3;">
        <text class="menu-icon-star">*</text>
      </view>
      <text class="menu-label">我的收藏</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-row" bindtap="goFeedback">
      <view class="menu-icon-box" style="background: #e9e7eb;">
        <text class="menu-icon-star">!</text>
      </view>
      <text class="menu-label">意见反馈</text>
      <text class="menu-arrow">></text>
    </view>

    <view class="menu-row" hover-class="none">
      <view class="menu-icon-box" style="background: #ffdad7;">
        <text class="menu-icon-star">?</text>
      </view>
      <button class="menu-label menu-contact-btn" open-type="contact">联系客服</button>
      <text class="menu-arrow">></text>
    </view>
  </view>

  <!-- 底部信息 -->
  <view class="footer">
    <text class="footer-link">隐私政策</text>
    <text class="footer-version">版本 2.4.1</text>
  </view>

</view>
