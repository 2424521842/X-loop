/* 个人中心页样式 */
.page-profile {
  min-height: 100vh;
  background: #f5f3f7;
  padding-bottom: 40rpx;
}

/* ========== 渐变头部 ========== */
.hero-header {
  position: relative;
  background: linear-gradient(135deg, #010544 0%, #CE57C1 100%);
  padding-bottom: 120rpx;
  overflow: hidden;
}

.hero-bg-x {
  position: absolute;
  top: -40rpx;
  right: -60rpx;
  font-size: 500rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.06);
  line-height: 1;
  pointer-events: none;
}

.hero-content {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 60rpx 0 20rpx;
  position: relative;
  z-index: 1;
}

/* 头像 */
.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx solid #ffffff;
  margin-bottom: 20rpx;
  box-shadow: 0 8rpx 32rpx rgba(0, 0, 0, 0.2);
}

.avatar-placeholder {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  border: 6rpx dashed rgba(255, 255, 255, 0.6);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 20rpx;
}

.avatar-placeholder-icon {
  font-size: 72rpx;
  color: rgba(255, 255, 255, 0.6);
  font-weight: 300;
}

/* 用户名 */
.user-name {
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.login-text {
  color: rgba(255, 255, 255, 0.85);
  font-size: 34rpx;
  font-weight: 500;
  margin-top: 4rpx;
}

/* 学校徽章 */
.school-badge {
  background: rgba(255, 255, 255, 0.18);
  border-radius: 24rpx;
  padding: 6rpx 24rpx;
  margin-top: 4rpx;
}

.school-badge-text {
  color: rgba(255, 255, 255, 0.9);
  font-size: 22rpx;
  letter-spacing: 1rpx;
}

/* ========== 统计浮动卡片 ========== */
.stats-card {
  display: flex;
  align-items: center;
  background: #ffffff;
  margin: -96rpx 32rpx 0;
  padding: 40rpx 20rpx;
  border-radius: 24rpx;
  box-shadow: 0 8rpx 40rpx rgba(1, 5, 68, 0.1);
  position: relative;
  z-index: 2;
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #cb55bf;
  margin-bottom: 8rpx;
}

.stats-label {
  font-size: 24rpx;
  color: #777681;
}

.stats-divider {
  width: 1rpx;
  height: 60rpx;
  background: #eee;
}

/* ========== 推广横幅卡片 ========== */
.promo-card {
  margin: 28rpx 32rpx 0;
  padding: 36rpx 40rpx;
  background: linear-gradient(135deg, #1a1068 0%, #6b2fa0 50%, #cb55bf 100%);
  border-radius: 24rpx;
  position: relative;
  overflow: hidden;
}

.promo-content {
  position: relative;
  z-index: 1;
}

.promo-title {
  display: block;
  font-size: 34rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 8rpx;
}

.promo-desc {
  display: block;
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-bottom: 24rpx;
}

.promo-btn {
  display: inline-flex;
  background: rgba(255, 255, 255, 0.2);
  border-radius: 32rpx;
  padding: 10rpx 32rpx;
}

.promo-btn-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

.promo-deco {
  position: absolute;
  right: -20rpx;
  top: -30rpx;
  font-size: 260rpx;
  font-weight: 900;
  color: rgba(255, 255, 255, 0.07);
  line-height: 1;
}

/* ========== 菜单列表 ========== */
.menu-card {
  margin: 28rpx 32rpx 0;
  background: #ffffff;
  border-radius: 24rpx;
  overflow: hidden;
  box-shadow: 0 4rpx 20rpx rgba(0, 0, 0, 0.04);
}

.menu-row {
  display: flex;
  align-items: center;
  padding: 28rpx 32rpx;
  position: relative;
}

.menu-row::after {
  content: '';
  position: absolute;
  left: 100rpx;
  right: 32rpx;
  bottom: 0;
  height: 1rpx;
  background: #f0f0f0;
}

.menu-row:last-child::after {
  display: none;
}

.menu-icon-box {
  width: 64rpx;
  height: 64rpx;
  border-radius: 16rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.menu-icon-star {
  font-size: 32rpx;
  color: #464650;
  font-weight: 700;
}

.menu-label {
  flex: 1;
  font-size: 30rpx;
  color: #1b1b1e;
  font-weight: 500;
}

/* 联系客服按钮重置 */
.menu-contact-btn {
  background: none;
  border: none;
  padding: 0;
  margin: 0;
  text-align: left;
  line-height: inherit;
  font-size: 30rpx;
  color: #1b1b1e;
  font-weight: 500;
}

.menu-contact-btn::after {
  display: none;
}

.menu-arrow {
  font-size: 28rpx;
  color: #c0bfc5;
  flex-shrink: 0;
}

/* ========== 底部信息 ========== */
.footer {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 48rpx 0 32rpx;
}

.footer-link {
  font-size: 24rpx;
  color: #cb55bf;
  margin-bottom: 8rpx;
}

.footer-version {
  font-size: 22rpx;
  color: #c0bfc5;
}
