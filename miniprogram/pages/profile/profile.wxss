/* 个人中心样式 */
.user-header {
  padding: 60rpx 30rpx 40rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
}

.user-avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255, 255, 255, 0.5);
  margin-bottom: 16rpx;
}

.user-name {
  color: #fff;
  font-size: 34rpx;
  font-weight: bold;
  margin-bottom: 8rpx;
}

.user-credit {
  color: rgba(255, 255, 255, 0.8);
  font-size: 24rpx;
}

.login-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
}

/* 统计 */
.stats-bar {
  margin: -30rpx 20rpx 20rpx;
  position: relative;
  z-index: 1;
  padding: 30rpx;
}

.stat-item {
  flex: 1;
}

.stat-num {
  font-size: 36rpx;
  font-weight: bold;
  color: #333;
  margin-bottom: 8rpx;
}

/* 菜单 */
.menu-list {
  margin: 0 20rpx 20rpx;
}

.menu-item {
  padding: 28rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
  font-size: 30rpx;
}

.menu-item:last-child {
  border-bottom: none;
}
