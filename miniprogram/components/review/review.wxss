.review-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
  margin: 20rpx;
}

.review-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20rpx;
}

.review-title {
  font-size: 30rpx;
  font-weight: bold;
  color: #333;
}

.review-count {
  font-size: 24rpx;
  color: #999;
}

.review-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.review-item:last-child {
  border-bottom: none;
}

.review-user {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.review-avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  margin-right: 16rpx;
}

.review-user-info {
  flex: 1;
}

.review-name {
  font-size: 26rpx;
  color: #333;
  display: block;
}

.review-stars {
  font-size: 24rpx;
  color: #f5a623;
}

.review-time {
  font-size: 22rpx;
  color: #ccc;
}

.review-content {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  padding-left: 80rpx;
}

.review-empty {
  text-align: center;
  padding: 40rpx 0;
}

.review-empty-text {
  font-size: 26rpx;
  color: #ccc;
}
